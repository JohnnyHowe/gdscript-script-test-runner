{
	"name": "gdscript-script-test-runner-vscode",
	"displayName": "GDScript Script Test Runner",
	"description": "VS Code integration for the GDScript Script Test Runner addon.",
	"version": "0.0.1",
	"publisher": "local",
	"license": "MIT",
	"engines": {
		"vscode": "^1.90.0"
	},
	"categories": [
		"Testing"
	],
	"activationEvents": [
		"workspaceContains:project.godot",
		"onLanguage:gdscript",
		"onStartupFinished"
	],
	"main": "./out/extension.js",
	"contributes": {
		"configuration": {
			"title": "GDScript Script Test Runner",
			"properties": {
				"gdscriptScriptTestRunner.projectPath": {
					"type": "string",
					"default": "",
					"scope": "resource",
					"description": "Path to the Godot project root, relative to the workspace folder or absolute. An empty value uses the workspace folder."
				}
			}
		},
		"commands": [
			{
				"command": "gdscriptScriptTestRunner.refreshTests",
				"title": "GDScript Test Runner: Refresh Tests"
			}
		]
	},
	"scripts": {
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"package": "vsce package --allow-missing-repository --out gdscript-script-test-runner-vscode.vsix",
		"install:local": "npm run compile && npm run package && code --install-extension gdscript-script-test-runner-vscode.vsix --force"
	},
	"devDependencies": {
		"@vscode/vsce": "^3.0.0",
		"@types/node": "^20.0.0",
		"@types/vscode": "^1.90.0",
		"typescript": "^5.0.0"
	}
}
