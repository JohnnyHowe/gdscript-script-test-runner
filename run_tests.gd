extends SceneTree   func _initialize(): 	var runner := ScriptTestRunner.new("res://")  	var args := UserArgumentParser.parse_cmdline_user_args() 	runner.filter = ScriptTestFilter.new(args.get("file_filter", ".*"), args.get("method_filter", ".*")) 	runner.assert_on_fail = args.get("assert_on_fail", false) 	runner.show_passed_tests = args.get("show_passed_tests", false) 	runner.show_unfiltered_test_files = args.get("show_unfiltered_test_files", false) 	runner.run()  	var failed_tests := runner.get_failed_test_count() 	var exit_code := 0 if failed_tests == 0 else 1 	_quit(exit_code)   func _quit(exit_code: int): 	for child in root.get_children(): 		child.free() 	quit(exit_code)